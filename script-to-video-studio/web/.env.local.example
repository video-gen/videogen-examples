# The Node backend base URL. (The local videogen backend uses :4000, so the
# example server runs on :4100.)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4100

# Firebase project id. A "demo-" id runs entirely on the local emulators with no
# real Firebase project. Any values work for the emulator.
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-script-to-video
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key

# Emulator hosts (defaults match firebase.json). Set NEXT_PUBLIC_USE_EMULATORS to
# "false" only if you wire up a real Firebase project.
NEXT_PUBLIC_USE_EMULATORS=true
NEXT_PUBLIC_AUTH_EMULATOR_URL=http://127.0.0.1:9099
NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST=127.0.0.1
NEXT_PUBLIC_FIRESTORE_EMULATOR_PORT=8080
