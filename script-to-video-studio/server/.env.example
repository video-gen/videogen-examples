# --- VideoGen ---
# Your developer API key from https://app.videogen.io/developers
# Monorepo local dev: run `pnpm setup:local-examples` from the repo root instead.
VIDEOGEN_API_KEY=

# Optional: override the API base URL (e.g. to hit a local API).
# Leave blank to use production (https://api.videogen.io).
# VIDEOGEN_API_URL=http://localhost:4010

# The "Generate script" button uses VideoGen's text generation endpoint
# (POST /v1/text/generate) — no extra LLM key required.

# --- Webhooks (optional) ---
# Webhooks are optional: the server always polls for progress, and uses webhooks
# as a fast-path for completion when configured.
#
# Option A: let the server auto-register an endpoint on startup. Set the public
# URL it should register (your tunnel, e.g. ngrok, or http://localhost:4100 when
# you point VIDEOGEN_API_URL at a local API). The server prints the signing
# secret on boot — paste it into VIDEOGEN_WEBHOOK_SECRET to reuse it.
# WEBHOOK_PUBLIC_URL=https://your-tunnel.ngrok.app
#
# Option B: register the endpoint yourself (dashboard or curl) and paste the
# signing secret here.
# VIDEOGEN_WEBHOOK_SECRET=whsec_...

# --- Server ---
# Avoid :4000 — the local videogen backend (pnpm dev:api) listens there.
PORT=4100
# Allowed browser origin for CORS (the Next.js app).
WEB_ORIGIN=http://localhost:3000

# --- Firebase (local emulators) ---
# A "demo-" project id makes the emulators run fully offline (no real project).
FIREBASE_PROJECT_ID=demo-script-to-video
# These default to the emulator config in firebase.json; override only if you
# changed the emulator ports.
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
