# Get your keys at:
# - VideoGen: https://app.videogen.io/developers
VIDEOGEN_API_KEY=your_videogen_api_key_here

# Webhook signing secret (returned when you register a webhook endpoint)
VIDEOGEN_WEBHOOK_SECRET=your_webhook_signing_secret_here

# Public URL for webhook delivery (use ngrok for local dev)
PUBLIC_URL=https://your-server.com
