# Get your keys at:
# - VideoGen: https://app.videogen.io/developers (or `pnpm setup:local-examples` in the monorepo)
# - OpenAI: https://platform.openai.com/api-keys
VIDEOGEN_API_KEY=your_videogen_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional: point at the local developer API (set automatically by `pnpm setup:local-examples`).
# VIDEOGEN_API_URL=http://localhost:4010
